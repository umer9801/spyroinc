# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/spyroinc

# Authentication
JWT_SECRET=your-secret-key-here
AUTH_ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
